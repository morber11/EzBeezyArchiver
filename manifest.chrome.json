{
    "manifest_version": 3,
    "name": "Easy Beezy Archiver",
    "version": "1.1",
    "description": "Archives the current page using an archiving service of your choice",
    "icons": {
        "48": "media/icon.png"
    },
    "background": {
        "service_worker": "index.js"
    },
    "action": {
        "default_icon": "media/icon.png",
        "default_title": "Archive this page"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "permissions": [
        "activeTab",
        "contextMenus",
        "storage"
    ]
}